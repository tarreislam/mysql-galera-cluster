# master/child
MYSQL_ROOT_PASSWORD=impulse101
# connections
MAX_CONNECTIONS=600
BACK_LOG=512
THREAD_CACHE_SIZE=200

# memory
INNODB_BUFFER_POOL_SIZE=1G
INNODB_BUFFER_POOL_INSTANCES=2
SORT_BUFFER_SIZE=4M
JOIN_BUFFER_SIZE=4M
READ_BUFFER_SIZE=2M
READ_RND_BUFFER_SIZE=2M
TMP_TABLE_SIZE=512M
MAX_HEAP_TABLE_SIZE=512M

# IO
INNODB_IO_CAPACITY=2000
INNODB_IO_CAPACITY_MAX=4000
INNODB_LOG_BUFFER_SIZE=256M

# misc
TABLE_OPEN_CACHE=4000
TABLE_DEFINITION_CACHE=2000
MAX_ALLOWED_PACKET=256M

WSREP_CLUSTER_NAME=MyCluster

WSREP_NODE_NAME=node-01
WSREP_NODE_ADDRESS=192.168.1.246

WSREP_CLUSTER_ADDRESS=192.168.1.246,192.168.1.246

WSREP_SST_DONOR=node-01,node-03
WSREP_SST_METHOD=mariabackup
WSREP_SST_AUTH_USER=sst_user
WSREP_SST_AUTH_PASS=sst_pass