# copy entire file after #connections and ask any LLM what u should put based on your computer.
MYSQL_ROLE="wsrep-new-cluster or nothing"
# Removes grastat for wsrep-new-cluster and sst_in progress on joining nodes
MYSQL_FORCE_SST="false"

MYSQL_ROOT_PASSWORD=root
TZ=Europe/Stockholm

# Backup
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_SCHEDULE_HOUR=23

# Generated by MariaDB env config generator
# Date:         2026-04-03
# MariaDB:      12.2 + Galera 4
# RAM:          8GB
# CPU cores:    8
# Disk:         NVME
# Network:      1 Gbit
# Max latency:  100ms

# ── connections ──────────────────────────────────────────
MAX_CONNECTIONS=100
BACK_LOG=256
THREAD_CACHE_SIZE=64

# ── memory ───────────────────────────────────────────────
INNODB_BUFFER_POOL_SIZE=5.6G
SORT_BUFFER_SIZE=1MM
JOIN_BUFFER_SIZE=1MM
READ_BUFFER_SIZE=1MM
READ_RND_BUFFER_SIZE=2MM
TMP_MEMORY_TABLE_SIZE=128M
MAX_HEAP_TABLE_SIZE=128M

# ── IO ───────────────────────────────────────────────────
INNODB_IO_CAPACITY=8000
INNODB_IO_CAPACITY_MAX=16000
INNODB_LOG_BUFFER_SIZE=64M

# ── misc ─────────────────────────────────────────────────
TABLE_OPEN_CACHE=512
TABLE_DEFINITION_CACHE=400
MAX_ALLOWED_PACKET=64M

# ── galera / wsrep (MariaDB 12.2 + Galera 4) ────────────
WSREP_SLAVE_THREADS=16
WSREP_MAX_WS_SIZE=64M
WSREP_PROVIDER_OPTIONS=evs.keepalive_period=PT1.0S;evs.suspect_timeout=PT5.0S;evs.inactive_timeout=PT15.0S;gcs.fc_limit=16

# Galera config
WSREP_RETRY_AUTOCOMMIT=2
WSREP_CLUSTER_NAME=MyCluster

WSREP_NODE_NAME=node-01
WSREP_NODE_ADDRESS=192.168.1.246

WSREP_CLUSTER_ADDRESS=192.168.1.246,192.168.1.246

WSREP_SST_DONOR=node-02,node-03
WSREP_SST_METHOD=mariabackup
WSREP_SST_AUTH_USER=sst_user
WSREP_SST_AUTH_PASS=sst_pass